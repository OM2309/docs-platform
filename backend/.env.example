# DocFlow Backend Environment Variables
# Copy to .env and fill in values

# Server
PORT=8080
ENVIRONMENT=development

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/docflow?sslmode=require

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this
JWT_EXPIRY=15m
REFRESH_EXPIRY=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3000
